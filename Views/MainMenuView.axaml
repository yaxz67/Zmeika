<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zmeika.Views.MainMenuView">
    
    <StackPanel Spacing="20" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Width="500">
        
        <TextBlock Text="🐍 ЗМЕЙКА БРАТАН 🐍" 
                   FontSize="32" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="#00FF00"/>
        
        <Border BorderBrush="#333" 
                BorderThickness="2" 
                CornerRadius="10" 
                Padding="20"
                Background="#1A1A1A">
            <StackPanel Spacing="15">
                
                <CheckBox Name="TeleportCheckBox"
                          Content="🌀 Телепорт при втыкании в стены" 
                          IsChecked="True"
                          Foreground="#00FF00"
                          FontSize="16"/>
                
                <CheckBox Name="RgbCheckBox"
                          Content="🌈 RGB змейка" 
                          IsChecked="False"
                          Foreground="#FF00FF"
                          FontSize="16"/>
                
                <!-- Слайдер скорости RGB -->
                <Border IsVisible="{Binding #RgbCheckBox.IsChecked}"
                        BorderBrush="#FF00FF"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="10"
                        Margin="0,5">
                    <StackPanel Spacing="5">
                        <TextBlock Text="🏳️‍🌈 Скорость RGB:" 
                                   Foreground="#FF88FF"
                                   FontSize="14"/>
                        
                        <Grid ColumnDefinitions="*,Auto" Margin="0,5,0,0">
                            <Slider Name="RgbSpeedSlider"
                                    Minimum="0.1"
                                    Maximum="5.0"
                                    Value="1.0"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    Grid.Column="0"/>
                            <TextBlock Name="RgbSpeedLabel"
                                       Text="1.0x"
                                       Foreground="#FF88FF"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Grid.Column="1"
                                       Margin="10,0,0,0"
                                       Width="50"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <Button x:Name="PlayButton"
                        Content="▶ ИГРАТЬ" 
                        Background="#00AA00"
                        Foreground="White"
                        FontSize="20"
                        FontWeight="Bold"
                        Height="50"
                        CornerRadius="5"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>