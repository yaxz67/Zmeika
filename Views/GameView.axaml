<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Zmeika.ViewModels"
             x:Class="Zmeika.Views.GameView"
             x:DataType="vm:GameViewModel"
             KeyDown="OnKeyDown"
             Focusable="True">
    
    <Grid Background="#0A0A0A">
        <Border Background="#111" 
                Width="{Binding CanvasWidth}" 
                Height="{Binding CanvasHeight}"
                BorderBrush="#333"
                BorderThickness="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Canvas x:Name="GameCanvas"/>
        </Border>
        
        <Border Background="#CC000000" 
                CornerRadius="0 0 10 10" 
                Padding="15,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <TextBlock Text="{Binding Score, StringFormat='🏆 {0}'}" 
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="#00FF00"
                       HorizontalAlignment="Center"/>
        </Border>
        
        <Border Background="#CC000000" 
                CornerRadius="10" 
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding IsGameOver}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="💀 GAME OVER 💀" 
                           FontSize="48" 
                           FontWeight="Bold"
                           Foreground="#FF4444"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Score, StringFormat='Счёт: {0}'}" 
                           FontSize="24" 
                           Foreground="#FF8800"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                <TextBlock Text="ESC - выход в меню" 
                           FontSize="18" 
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>